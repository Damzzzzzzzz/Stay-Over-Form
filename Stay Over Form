        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  TIME PICKER
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        function initTimePicker() {
            const hourWheel = document.getElementById('hourWheel');
            const minuteWheel = document.getElementById('minuteWheel');

            for (let i = 1; i <= 12; i++) {
                const div = document.createElement('div');
                div.className = 'picker-item';
                div.textContent = i;
                div.dataset.value = i;
                hourWheel.appendChild(div);
            }
            for (let i = 0; i < 60; i += 5) {
                const div = document.createElement('div');
                div.className = 'picker-item';
                div.textContent = String(i).padStart(2, '0');
                div.dataset.value = i;
                minuteWheel.appendChild(div);
            }

            document.querySelectorAll('#ampmWheel .picker-item').forEach(el => {
                el.addEventListener('click', function() {
                    document.querySelectorAll('#ampmWheel .picker-item').forEach(e => e.classList.remove('active'));
                    this.classList.add('active');
                    tempAmPm = this.dataset.value;
                    filterHourWheelForArrival();
                });
            });

            hourWheel.addEventListener('scroll', () => updateWheelSelection(hourWheel, 'hour'));
            minuteWheel.addEventListener('scroll', () => updateWheelSelection(minuteWheel, 'minute'));
            hourWheel.addEventListener('click', (e) => { const item = e.target.closest('.picker-item'); if (item) { item
                        .scrollIntoView({ block: 'center', behavior: 'smooth' });
                    setTimeout(() => updateWheelSelection(hourWheel, 'hour'), 200); } });
            minuteWheel.addEventListener('click', (e) => { const item = e.target.closest('.picker-item'); if (item) { item
                        .scrollIntoView({ block: 'center', behavior: 'smooth' });
                    setTimeout(() => updateWheelSelection(minuteWheel, 'minute'), 200); } });

            tempHour = 9;
            tempMinute = 0;
            tempAmPm = 'AM';
            setTimeout(() => {
                setWheelValue(hourWheel, 9);
                setWheelValue(minuteWheel, 0);
                document.querySelectorAll('#ampmWheel .picker-item').forEach(el => el.classList.toggle('active', el
                    .dataset.value === 'AM'));
                filterHourWheelForArrival();
            }, 100);
        }

        function filterHourWheelForArrival() {
            const hourWheel = document.getElementById('hourWheel');
            const items = hourWheel.querySelectorAll('.picker-item');
            const isAM = tempAmPm === 'AM';
            items.forEach(item => {
                const val = parseInt(item.dataset.value);
                let visible = false;
                if (isAM) {
                    if (val >= 9 && val <= 11) visible = true;
                } else {
                    if (val === 12 || (val >= 1 && val <= 7)) visible = true;
                }
                item.style.display = visible ? '' : 'none';
                if (!visible) item.classList.remove('active');
            });
            const active = hourWheel.querySelector('.picker-item.active');
            if (!active || active.style.display === 'none') {
                let found = false;
                items.forEach(item => {
                    if (item.style.display !== 'none' && !found) {
                        item.classList.add('active');
                        tempHour = parseInt(item.dataset.value);
                        found = true;
                    }
                });
                if (!found) {
                    items.forEach(item => {
                        if (parseInt(item.dataset.value) === 9) {
                            item.style.display = '';
                            item.classList.add('active');
                            tempHour = 9;
                        }
                    });
                }
            }
        }

        function updateWheelSelection(wheel, type) {
            const items = wheel.querySelectorAll('.picker-item:not([style*="display: none"])');
            let closest = null,
                closestDist = Infinity;
            const wheelRect = wheel.getBoundingClientRect();
            const centerY = wheelRect.top + wheelRect.height / 2;
            items.forEach(item => {
                const rect = item.getBoundingClientRect();
                const itemCenter = rect.top + rect.height / 2;
                const dist = Math.abs(itemCenter - centerY);
                if (dist < closestDist) { closestDist = dist;
                    closest = item; }
            });
            wheel.querySelectorAll('.picker-item').forEach(item => item.classList.remove('active'));
            if (closest) {
                closest.classList.add('active');
                const val = parseInt(closest.dataset.value);
                if (type === 'hour') tempHour = val;
                else if (type === 'minute') tempMinute = val;
            }
        }

        function setWheelValue(wheel, value) {
            const items = wheel.querySelectorAll('.picker-item');
            let target = null;
            items.forEach(item => {
                if (parseInt(item.dataset.value) === value) target = item;
                item.classList.remove('active');
            });
            if (target) {
                target.classList.add('active');
                target.scrollIntoView({ block: 'center', behavior: 'smooth' });
            }
        }

        function openTimePicker(type) {
            if (type === 'dep') return;
            activeTimePicker = 'arr';
            document.getElementById('timePickerModal').classList.add('open');
            let h = tempHour,
                m = tempMinute,
                ap = tempAmPm;
            const existing = document.getElementById('arrTime').value;
            if (existing) {
                const parts = existing.split(' ');
                if (parts.length === 2) {
                    const timeParts = parts[0].split(':');
                    const hr = parseInt(timeParts[0]);
                    const min = parseInt(timeParts[1]);
                    h = hr % 12 || 12;
                    m = Math.round(min / 5) * 5;
                    ap = parts[1];
                    tempHour = h;
                    tempMinute = m;
                    tempAmPm = ap;
                }
            }
            setTimeout(() => {
                setWheelValue(document.getElementById('hourWheel'), h);
                setWheelValue(document.getElementById('minuteWheel'), m);
                document.querySelectorAll('#ampmWheel .picker-item').forEach(el => el.classList.toggle('active', el
                    .dataset.value === ap));
                filterHourWheelForArrival();
            }, 150);
            document.querySelectorAll('.time-picker-trigger').forEach(t => t.classList.remove('active'));
            document.getElementById('arrTimeTrigger').classList.add('active');
        }

        function closeTimePicker() {
            document.getElementById('timePickerModal').classList.remove('open');
            document.querySelectorAll('.time-picker-trigger').forEach(t => t.classList.remove('active'));
        }

        function confirmTimePicker() {
            if (!activeTimePicker) return;
            const hourItems = document.querySelectorAll('#hourWheel .picker-item');
            const minItems = document.querySelectorAll('#minuteWheel .picker-item');
            let h = tempHour,
                m = tempMinute,
                ap = tempAmPm;
            hourItems.forEach(el => { if (el.classList.contains('active')) h = parseInt(el.dataset.value); });
            minItems.forEach(el => { if (el.classList.contains('active')) m = parseInt(el.dataset.value); });
            document.querySelectorAll('#ampmWheel .picker-item').forEach(el => { if (el.classList.contains('active')) ap = el
                    .dataset.value; });

            let hour12 = h;
            let displayStr = `${hour12}:${String(m).padStart(2,'0')} ${ap}`;

            let hour24 = h;
            if (ap === 'PM' && h !== 12) hour24 = h + 12;
            if (ap === 'AM' && h === 12) hour24 = 0;
            const totalMinutes = hour24 * 60 + m;
            const minValid = 9 * 60;
            const maxValid = 19 * 60 + 30;

            if (totalMinutes < minValid || totalMinutes > maxValid) {
                showToast('Time Error', 'Arrival time must be between 9:00 AM and 7:30 PM.', false);
                return;
            }

            const display = document.getElementById('arrTimeDisplay');
            const hidden = document.getElementById('arrTime');
            hidden.value = displayStr;
            display.textContent = displayStr;
            display.classList.remove('placeholder');
            closeTimePicker();
        }

        document.getElementById('timePickerModal').addEventListener('click', function(e) {
            if (e.target === this) closeTimePicker();
        });

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  CHECKOUT FUNCTION
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        function markCheckedOut(firebaseId) {
            const entry = records.find(r => r.firebaseId === firebaseId);
            if (!entry) {
                showToast('Error', 'Record not found.', false);
                return;
            }

            if (entry.checkedOut === true) {
                showToast('Already Checked Out', 'This guest has already been marked as checked out.', true);
                return;
            }

            if (entry.status !== 'Approved') {
                showToast('Not Approved', 'Only approved stays can be checked out.', false);
                return;
            }

            if (confirm(`Confirm check-out for ${entry.name} (Room ${entry.hostRoom})?`)) {
                const ref = db.ref('stayOverRecords').child(firebaseId);
                ref.update({
                    checkedOut: true,
                    checkedOutAt: new Date().toISOString(),
                    checkedOutBy: 'Admin'
                }).then(() => {
                    showToast('Checked Out', `${entry.name} has been marked as checked out.`, true);
                    // The Firebase listener will update the UI automatically
                }).catch((error) => {
                    console.error('Checkout error:', error);
                    showToast('Error', 'Could not mark as checked out. Please try again.', false);
                });
            }
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  SUBMIT REQUEST
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        let isSubmitting = false;

        function submitRequest() {
            if (isSubmitting) return;
            document.querySelectorAll('.input-error').forEach(el => el.classList.remove('input-error'));

            let hasError = false;
            const textFields = ['fname', 'fid', 'femail', 'emContact', 'hostTower', 'hostName', 'hostId', 'arrDate',
                'depDate', 'reasonType'
            ];
            textFields.forEach(id => {
                const el = document.getElementById(id);
                if (!el || !el.value.trim()) { if (el) el.classList.add('input-error');
                    hasError = true; }
            });
            if (!document.getElementById('arrTime').value) { document.getElementById('arrTimeTrigger').classList.add(
                    'input-error');
                hasError = true; }
            if (!document.getElementById('selectedRoomCode').value) { document.getElementById('roomSelectorContainer')
                    .classList.add('input-error');
                hasError = true; }

            const arrDateVal = document.getElementById('arrDate').value;
            if (arrDateVal) {
                const today = getToday();
                const arrDate = strToDate(arrDateVal);
                const minDate = getMinDate();
                if (arrDate && arrDate < minDate) {
                    document.getElementById('arrDateTrigger').classList.add('input-error');
                    hasError = true;
                    showToast('Advance Booking Error', 'Arrival date must be at least 3 days from today.', false);
                    return;
                }
            }

            if (hasError) {
                const firstError = document.querySelector('.input-error');
                if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                return showToast('Information Deficit', 'Please fill in all highlighted fields.', false);
            }

            const requestId = generateRequestId();

            const entry = {
                requestId: requestId,
                id: Date.now(),
                timestamp: new Date().toLocaleString(),
                name: document.getElementById('fname').value.trim(),
                studentId: document.getElementById('fid').value.trim(),
                email: document.getElementById('femail').value.trim(),
                emContact: document.getElementById('emContact').value.trim(),
                hostTowerId: document.getElementById('hostTower').value,
                hostRoom: document.getElementById('selectedRoomCode').value,
                hostName: document.getElementById('hostName').value.trim(),
                hostId: document.getElementById('hostId').value.trim(),
                arrDate: document.getElementById('arrDate').value,
                arrTime: document.getElementById('arrTime').value,
                depDate: document.getElementById('depDate').value,
                depTime: '11:00 AM',
                reasonType: document.getElementById('reasonType').value,
                reasonText: document.getElementById('reasonText').value.trim(),
                status: 'Pending',
                checkedOut: false,
                checkedOutAt: null,
                checkedOutBy: null
            };

            if (entry.arrDate > entry.depDate) return showToast('Chronological Error', 'Departure date must be on or after arrival date.',
                false);

            isSubmitting = true;
            const submitBtn = document.getElementById('submitBtnDesktop');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending...';

            const ref = db.ref('stayOverRecords');
            ref.push(entry)
                .then(() => {
                    ['fname', 'fid', 'femail', 'emContact', 'hostTower', 'hostName', 'hostId', 'arrDate', 'depDate',
                        'reasonType', 'reasonText'
                    ].forEach(id => {
                        const el = document.getElementById(id);
                        if (el) { if (el.tagName === 'SELECT') el.selectedIndex = 0;
                            else el.value = ''; }
                    });
                    ['arr', 'dep'].forEach(t => {
                        if (t === 'arr') {
                            document.getElementById('arrTime').value = '';
                            const disp = document.getElementById('arrTimeDisplay');
                            disp.textContent = 'Select time';
                            disp.classList.add('placeholder');
                        }
                    });
                    document.getElementById('selectedRoomCode').value = '';
                    document.getElementById('activeRoomDisplay').style.display = 'none';
                    document.getElementById('roomSelectorContainer').style.display = 'none';
                    document.getElementById('dynamicGrid').innerHTML = '';
                    if (chkRules) chkRules.checked = false;
                    if (chkConsent) chkConsent.checked = false;
                    updateDemographicNote('');
                    document.getElementById('arrivalDateDisplay').textContent = '';
                    document.getElementById('departureDateDisplay').textContent = '';

                    document.getElementById('depTime').value = '11:00 AM';

                    const minDate = getMinDate();
                    document.getElementById('arrDate').value = dateToStr(minDate);
                    const arrDisplay = document.getElementById('arrDateDisplay');
                    arrDisplay.textContent = formatDateDisplay(minDate);
                    arrDisplay.classList.remove('placeholder');
                    document.getElementById('arrivalDateDisplay').textContent = formatDateShort(dateToStr(minDate));

                    const defaultDep = new Date(minDate);
                    defaultDep.setDate(minDate.getDate() + 1);
                    document.getElementById('depDate').value = dateToStr(defaultDep);
                    const depDisplay = document.getElementById('depDateDisplay');
                    depDisplay.textContent = formatDateDisplay(defaultDep);
                    depDisplay.classList.remove('placeholder');
                    document.getElementById('departureDateDisplay').textContent = formatDateShort(dateToStr(defaultDep));

                    window._arrDateObj = minDate;
                    window._depDateObj = defaultDep;

                    Promise.all([
                        sendStudentEmail(entry, 'new'),
                        sendAdminEmail(entry)
                    ]).then(([studentResult, adminResult]) => {
                        if (studentResult || adminResult) {
                            showToast('Request Submitted!',
                                `Your request has been sent. Your Request ID is: ${entry.requestId}. Please keep it safe. The Off-Campus Representative will review it shortly.`,
                                true);
                        } else {
                            showToast('Request Submitted',
                                `Your request was saved, but email notifications could not be sent. Your Request ID is: ${entry.requestId}. Please keep it safe.`,
                                false);
                        }
                    }).catch(() => {
                        showToast('Request Submitted',
                            `Your request was saved, but email notifications could not be sent. Your Request ID is: ${entry.requestId}. Please keep it safe.`,
                            false);
                    }).finally(() => {
                        isSubmitting = false;
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'Transmit Registry Data →';
                    });

                    document.getElementById('lookupRequestId').value = entry.requestId;
                    switchTab('manage');
                    lookupById();
                })
                .catch((error) => {
                    console.error('Firebase push error:', error);
                    showToast('Error', 'Could not save request. Please try again.', false);
                    isSubmitting = false;
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Transmit Registry Data →';
                });
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  LOOKUP FUNCTIONS
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        function lookupById() {
            const requestId = document.getElementById('lookupRequestId').value.trim();
            const el = document.getElementById('myBookings');
            if (!requestId) { el.innerHTML = '<div class="empty-state">Please enter a Request ID.</div>'; return; }

            const myReqs = records.filter(r => r.requestId === requestId);
            if (!myReqs.length) { el.innerHTML = '<div class="empty-state">No booking found with that Request ID.</div>';
                return; }
            el.innerHTML = myReqs.map(r => {
                const cls = r.status === 'Approved' ? 'status-approved' : r.status === 'Rejected' ?
                    'status-declined' : 'status-pending';
                const timeLabel = r.arrTime && r.depTime ? `${r.arrTime} – ${r.depTime}` : 'Times not specified';
                const checkedOutStatus = r.checkedOut ? ' ✓ Checked Out' : '';
                return `
              <div class="booking-item" style="border:1px solid var(--border);padding:10px;border-radius:8px;margin-bottom:6px;background:var(--surface2);">
                <div class="booking-info">
                  <div class="booking-name">Request ID: ${r.requestId}</div>
                  <div class="booking-meta">Host: ${r.hostName} (ID: ${r.hostId || 'N/A'}) | Room ${r.hostRoom}</div>
                  <div class="booking-meta2">${formatDate(r.arrDate)} to ${formatDate(r.depDate)} · ${timeLabel}</div>
                  <div style="margin-top:4px;font-size:0.7rem;font-family:'DM Mono',monospace;" class="${cls}">Status: ${r.status.toUpperCase()}${checkedOutStatus}</div>
                  ${r.status === 'Approved' ? `<div style="margin-top:3px;font-size:0.6rem;color:var(--amber);">⏰ Must vacate by 11:00 AM on ${formatDate(r.depDate)}</div>` : ''}
                </div>
              </div>
            `;
            }).join('');
        }

        function lookupByEmail() {
            const email = document.getElementById('lookupEmail').value.trim().toLowerCase();
            const el = document.getElementById('myBookings');
            if (!email) { el.innerHTML = '<div class="empty-state">Enter an email to search.</div>'; return; }

            const myReqs = records.filter(r => r.email.toLowerCase() === email);
            if (!myReqs.length) { el.innerHTML = '<div class="empty-state">No bookings found for that email.</div>';
                return; }
            el.innerHTML = myReqs.map(r => {
                const cls = r.status === 'Approved' ? 'status-approved' : r.status === 'Rejected' ?
                    'status-declined' : 'status-pending';
                const timeLabel = r.arrTime && r.depTime ? `${r.arrTime} – ${r.depTime}` : 'Times not specified';
                const checkedOutStatus = r.checkedOut ? ' ✓ Checked Out' : '';
                return `
              <div class="booking-item" style="border:1px solid var(--border);padding:10px;border-radius:8px;margin-bottom:6px;background:var(--surface2);">
                <div class="booking-info">
                  <div class="booking-name">Request ID: ${r.requestId}</div>
                  <div class="booking-meta">Host: ${r.hostName} (ID: ${r.hostId || 'N/A'}) | Room ${r.hostRoom}</div>
                  <div class="booking-meta2">${formatDate(r.arrDate)} to ${formatDate(r.depDate)} · ${timeLabel}</div>
                  <div style="margin-top:4px;font-size:0.7rem;font-family:'DM Mono',monospace;" class="${cls}">Status: ${r.status.toUpperCase()}${checkedOutStatus}</div>
                  ${r.status === 'Approved' ? `<div style="margin-top:3px;font-size:0.6rem;color:var(--amber);">⏰ Must vacate by 11:00 AM on ${formatDate(r.depDate)}</div>` : ''}
                </div>
              </div>
            `;
            }).join('');
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  ADMIN CONSOLE
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        document.getElementById('publicBtn').addEventListener('click', () => {
            entryScreen.classList.add('hide');
            setTimeout(() => {
                entryScreen.style.display = 'none';
                mainApp.classList.add('visible');
                isAdminLoggedIn = false;
                updateVisibilityForRole();
                switchTab('book');
            }, 400);
        });

        document.getElementById('adminLoginBtnEntry').addEventListener('click', () => handleAdminConsoleAuth(true));

        function toggleAdmin() {
            if (!isAdminLoggedIn) handleAdminConsoleAuth(false);
            else switchTab('admin');
        }

        function handleAdminConsoleAuth(fromEntry) {
            const pwd = prompt("Enter Administrative Access Phrase:");
            if (pwd === "081604") {
                isAdminLoggedIn = true;
                document.getElementById('adminHeaderBtn').style.display = 'block';
                document.getElementById('btn-book').style.display = 'none';
                document.getElementById('btn-manage').style.display = 'none';
                document.getElementById('btn-admin').style.display = 'block';
                updateVisibilityForRole();
                if (fromEntry) {
                    entryScreen.classList.add('hide');
                    setTimeout(() => {
                        entryScreen.style.display = 'none';
                        mainApp.classList.add('visible');
                        switchTab('admin');
                    }, 400);
                } else {
                    switchTab('admin');
                }
                showToast('Console Verified', 'Welcome, Off-Campus Representative.', true);
                updateDashboardUI();
            } else {
                showToast('Authentication Interrupted', 'Access denied.', false);
            }
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  SET STATUS – UPDATE FIREBASE
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        function setStatus(firebaseId, newStatus) {
            const entry = records.find(r => r.firebaseId === firebaseId);
            if (!entry) {
                showToast('Error', 'Record not found.', false);
                return;
            }

            const oldStatus = entry.status;
            if (oldStatus === newStatus) {
                showToast('Status Mutated', `Log already ${newStatus}.`, true);
                return;
            }

            const ref = db.ref('stayOverRecords').child(firebaseId);
            ref.update({ status: newStatus })
                .then(() => {
                    let actionType = newStatus.toLowerCase();
                    if (actionType === 'rejected') actionType = 'declined';
                    sendStudentEmail(entry, actionType)
                        .then(() => {
                            showToast('Status Mutated', `Log re-assigned to ${newStatus}. Email notification sent to the student.`,
                                true);
                        })
                        .catch(() => {
                            showToast('Status Mutated', `Log re-assigned to ${newStatus}. But email notification could not be sent.`,
                                false);
                        });
                })
                .catch((error) => {
                    console.error('Firebase update error:', error);
                    showToast('Error', 'Could not update status. Please try again.', false);
                });
        }

        function deleteRecord(firebaseId) {
            if (confirm('Purge structural data profile permanently?')) {
                const ref = db.ref('stayOverRecords').child(firebaseId);
                ref.remove()
                    .then(() => {
                        showToast('Profile Purged', 'Registry record excised from matrix.', true);
                    })
                    .catch((error) => {
                        console.error('Firebase delete error:', error);
                        showToast('Error', 'Could not delete record. Please try again.', false);
                    });
            }
        }

        function renderAdminList() {
            const el = document.getElementById('adminRequestsList');
            if (!el) return;
            if (!records.length) { el.innerHTML = '<div class="empty-state">No structural records present.</div>'; return; }
            const sorted = [...records].sort((a, b) => a.status === 'Pending' ? -1 : 1);
            el.innerHTML = sorted.map(r => {
                const cls = r.status === 'Approved' ? 'status-approved' : r.status === 'Rejected' ?
                    'status-declined' : 'status-pending';
                const isCheckedOut = r.checkedOut === true;

                let actions = '';
                if (r.status === 'Pending') {
                    actions = `
                <button class="action-btn approve" onclick="setStatus('${r.firebaseId}','Approved')">Approve Entry</button>
                <button class="action-btn" onclick="setStatus('${r.firebaseId}','Rejected')">Decline</button>
              `;
                } else if (r.status === 'Approved') {
                    if (isCheckedOut) {
                        actions = `
                  <span style="color:var(--checkedout);font-size:0.6rem;font-family:'DM Mono',monospace;">✓ Checked Out</span>
                  <button class="action-btn" onclick="deleteRecord('${r.firebaseId}')">Purge Logs</button>
                `;
                    } else {
                        actions = `
                  <button class="action-btn checkout-btn" onclick="markCheckedOut('${r.firebaseId}')">✓ Mark Checked Out</button>
                  <button class="action-btn" onclick="deleteRecord('${r.firebaseId}')">Purge Logs</button>
                `;
                    }
                } else {
                    actions = `<button class="action-btn" onclick="deleteRecord('${r.firebaseId}')">Purge Logs</button>`;
                }

                const timeLabel = r.arrTime && r.depTime ? `${r.arrTime} – ${r.depTime}` : 'Times not specified';
                const checkedOutStatus = isCheckedOut ?
                    `<span style="color:var(--checkedout);font-size:0.65rem;font-family:'DM Mono',monospace;">✓ Checked Out</span>` :
                    r.status === 'Approved' ?
                    `<span style="color:var(--green);font-size:0.65rem;font-family:'DM Mono',monospace;">● Active</span>` :
                    '';

                return `
              <div class="booking-item" style="flex-direction:column;gap:8px;background:var(--surface2);padding:1rem;border-radius:10px;border:1px solid var(--border);">
                <div style="display:flex;justify-content:space-between;width:100%;border-bottom:1px solid rgba(255,255,255,0.03);padding-bottom:4px;flex-wrap:wrap;gap:4px;">
                  <div class="booking-name" style="font-size:0.9rem;">${r.name} <span style="font-weight:normal;color:var(--muted);font-size:0.75rem;">[ID: ${r.studentId}]</span></div>
                  <div style="display:flex;gap:8px;align-items:center;">
                    <span class="${cls}" style="font-size:0.65rem;font-family:'DM Mono',monospace;font-weight:600;">// ${r.status.toUpperCase()}</span>
                    ${checkedOutStatus}
                  </div>
                </div>
                <div style="display:grid;grid-template-columns:1fr;gap:4px;font-size:0.75rem;color:#D8D8D8;">
                  <div><strong>Request ID:</strong> ${r.requestId}</div>
                  <div><strong>Target Placement:</strong> Tower ${r.hostTowerId} | Room ${r.hostRoom}</div>
                  <div><strong>Host:</strong> ${r.hostName} (ID: ${r.hostId || 'N/A'})</div>
                  <div><strong>Temporal Scope:</strong> From ${formatDate(r.arrDate)} (${r.arrTime}) to ${formatDate(r.depDate)} (${r.depTime})</div>
                  <div><strong>Contact Vector:</strong> ${r.email} | Contact No: ${r.emContact}</div>
                  ${isCheckedOut ? `<div style="color:var(--checkedout);"><strong>Checked Out At:</strong> ${r.checkedOutAt ? new Date(r.checkedOutAt).toLocaleString() : 'N/A'} by ${r.checkedOutBy || 'Admin'}</div>` : ''}
                  <div style="margin-top:3px;padding:4px 8px;background:rgba(0,0,0,0.2);border-radius:4px;border-left:2px solid var(--red);"><strong>Justification:</strong> ${r.reasonType} — <em>"${r.reasonText}"</em></div>
                  <div style="margin-top:3px;padding:4px 8px;background:rgba(245,158,11,0.08);border-radius:4px;border-left:2px solid var(--amber);color:var(--amber);font-size:0.7rem;">
                    ⏰ <strong>Departure Deadline:</strong> Must vacate by 11:00 AM on ${formatDate(r.depDate)}. Sanctions: formal warning, daily account charges, suspension.
                  </div>
                </div>
                <div style="display:flex;justify-content:flex-end;width:100%;gap:6px;margin-top:2px;flex-wrap:wrap;">${actions}</div>
              </div>
            `;
            }).join('');
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  CLOSE MODALS ON BACKGROUND CLICK
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        document.getElementById('datePickerModal').addEventListener('click', function(e) {
            if (e.target === this) closeDatePicker();
        });
        document.getElementById('timePickerModal').addEventListener('click', function(e) {
            if (e.target === this) closeTimePicker();
        });
    </script>
</body>
</html>
