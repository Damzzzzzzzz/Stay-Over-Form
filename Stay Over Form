<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Stay-Over Authorization Portal | Towers Hall</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js">
    </script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js">
    </script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js">
    </script>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        :root {
            --red: #E31837;
            --red-dark: #990B1B;
            --red-glow: rgba(227, 24, 55, 0.15);
            --silver: #E0E0E0;
            --silver-dark: #A0A0A0;
            --silver-glow: rgba(224, 224, 224, 0.15);
            --black: #050505;
            --surface: #121212;
            --surface2: #1A1A1A;
            --border: rgba(255, 255, 255, 0.06);
            --text: #F5F5F5;
            --muted: #888;
            --green: #22c55e;
            --admin: #A78BFA;
            --green-glow: rgba(34, 197, 94, 0.12);
            --amber: #F59E0B;
            --amber-glow: rgba(245, 158, 11, 0.12);
            --gold: #D4AF37;
            --purple: #9B59B6;
            --turquoise: #1ABC9C;
            --royalblue: #4169E1;
            --dragon-red: #E31837;
            --checkedout: #6B7280;
        }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--black);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 999;
        }

        .entry-screen {
            position: fixed;
            inset: 0;
            background: radial-gradient(circle at 50% 40%, #1a0305 0%, #020202 100%);
            z-index: 1000;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: opacity 0.4s, visibility 0.4s;
            padding: 0.8rem;
            overflow: hidden !important;
        }
        .entry-screen.hide {
            opacity: 0;
            visibility: hidden;
        }
        .entry-content {
            background: rgba(18, 18, 18, 0.85);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            border-top: 4px solid var(--red);
            border-radius: 24px;
            padding: 2rem 1.5rem;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8), 0 0 70px var(--red-glow);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            max-width: 600px;
            width: 100%;
            animation: fadeUp 0.7s ease both;
            max-height: 98vh;
            overflow: hidden !important;
        }
        .entry-logos {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
            margin-bottom: 1.2rem;
            width: 100%;
            flex-shrink: 0;
        }
        .entry-logos .towers-logo {
            order: 0;
        }
        .entry-logos .offcampus-logo {
            order: 1;
        }
        .towers-logo img,
        .offcampus-logo img {
            width: 80px;
            height: 80px;
            object-fit: contain;
            filter: drop-shadow(0 0 12px var(--red-glow));
        }
        .entry-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 3.2rem;
            letter-spacing: 0.03em;
            line-height: 1;
            margin-top: 0;
            flex-shrink: 0;
        }
        .entry-title span {
            color: var(--red);
        }
        .entry-hall {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.1rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            margin: 0.2rem 0 1rem;
            color: var(--silver-dark);
            line-height: 1.3;
            flex-shrink: 0;
        }
        .entry-hall .towers-name {
            color: var(--silver);
        }
        .entry-hall span {
            color: var(--red);
        }
        .entry-notices {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-bottom: 1.5rem;
            text-align: left;
            flex-shrink: 0;
        }
        .entry-notice-item {
            background: rgba(26, 26, 26, 0.5);
            border-left: 3px solid var(--silver);
            border-radius: 8px;
            padding: 0.7rem 0.9rem;
            font-size: 0.75rem;
            line-height: 1.5;
            color: #E0E0E0;
            border: 1px solid rgba(255, 255, 255, 0.01);
        }
        .entry-notice-item.critical {
            border-left-color: var(--red);
            background: rgba(227, 24, 55, 0.04);
        }
        .entry-notice-item strong {
            color: var(--silver);
            font-weight: 600;
            display: block;
            margin-bottom: 3px;
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
            font-size: 0.65rem;
            letter-spacing: 0.05em;
        }
        .entry-notice-item.critical strong {
            color: var(--red);
        }
        .entry-notice-item .rule-highlight {
            color: var(--amber);
            font-weight: 600;
        }
        .entry-notice-item .rule-highlight2 {
            color: var(--green);
            font-weight: 600;
        }
        .entry-buttons {
            display: flex;
            gap: 0.7rem;
            flex-wrap: wrap;
            justify-content: center;
            width: 100%;
            flex-shrink: 0;
        }
        .entry-btn {
            padding: 0.8rem 1.2rem;
            font-size: 1rem;
            font-family: 'Bebas Neue', sans-serif;
            letter-spacing: 0.08em;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.25s;
            flex: 1;
            min-width: 140px;
        }
        .entry-btn.red {
            background: var(--red);
            color: white;
            box-shadow: 0 4px 15px rgba(227, 24, 55, 0.3);
        }
        .entry-btn.red:hover {
            background: var(--red-dark);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(227, 24, 55, 0.45);
        }
        .entry-btn.silver {
            background: transparent;
            color: var(--silver);
            border: 1px solid rgba(224, 224, 224, 0.3);
        }
        .entry-btn.silver:hover {
            background: rgba(224, 224, 224, 0.06);
            border-color: var(--silver);
            color: #fff;
            transform: translateY(-2px);
        }

        .main-app {
            display: none;
        }
        .main-app.visible {
            display: block;
        }
        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(5, 5, 5, 0.92);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 60px;
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }
        .logo img {
            width: 30px;
            height: 30px;
            object-fit: contain;
        }
        .logo-text {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.3rem;
            letter-spacing: 0.04em;
        }
        .logo-text span {
            color: var(--red);
        }
        .nav-status {
            font-family: 'DM Mono', monospace;
            font-size: 0.65rem;
            color: var(--muted);
            letter-spacing: 0.08em;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .status-dot {
            display: inline-block;
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--green);
            margin-right: 4px;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%,
            100% {
                opacity: 1;
            }
            50% {
                opacity: 0.25;
            }
        }
        .admin-login-btn {
            background: none;
            border: 1px solid var(--border);
            color: var(--muted);
            border-radius: 6px;
            padding: 4px 8px;
            font-size: 0.6rem;
            cursor: pointer;
            font-family: 'DM Mono', monospace;
            transition: all 0.2s;
            position: relative;
        }
        .admin-login-btn:hover {
            border-color: var(--admin);
            color: var(--admin);
        }
        .pending-badge {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--red);
            color: white;
            border-radius: 20px;
            padding: 1px 5px;
            font-size: 0.5rem;
            font-weight: bold;
            display: none;
        }
        .tab-badge {
            display: none;
            background: var(--red);
            color: white;
            border-radius: 20px;
            padding: 1px 6px;
            font-size: 0.55rem;
            font-weight: bold;
            margin-left: 4px;
        }

        .hero {
            padding: 1.5rem 1.5rem 1rem;
            max-width: 1000px;
            margin: 0 auto;
            text-align: center;
            animation: fadeUp 0.6s ease both;
        }
        .hero-logos {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 2rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }
        .hero-logos img {
            width: 120px;
            height: 120px;
            object-fit: contain;
            filter: drop-shadow(0 0 20px var(--red-glow));
        }
        .hero-label {
            font-family: 'DM Mono', monospace;
            font-size: 0.65rem;
            letter-spacing: 0.15em;
            color: var(--silver-dark);
            text-transform: uppercase;
            margin-bottom: 0.4rem;
        }
        h1 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(2.4rem, 6vw, 4rem);
            line-height: 0.95;
            letter-spacing: 0.01em;
            margin-bottom: 0.5rem;
        }
        h1 em {
            color: var(--red);
            font-style: normal;
        }
        .hero-sub {
            color: var(--muted);
            font-size: 0.85rem;
            max-width: 500px;
            margin: 0 auto 1.5rem;
            line-height: 1.6;
        }

        .capacity-bar-wrap {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 1rem 1.5rem;
            max-width: 1000px;
            margin: 0 auto 2rem;
            display: flex;
            align-items: center;
            gap: 1.2rem;
            animation: fadeUp 0.6s 0.05s ease both;
        }
        .cap-info {
            flex: 1;
        }
        .cap-label {
            font-size: 0.65rem;
            color: var(--muted);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
            margin-bottom: 4px;
        }
        .cap-track {
            height: 4px;
            background: var(--surface2);
            border-radius: 3px;
            overflow: hidden;
        }
        .cap-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--red), var(--silver-dark));
            border-radius: 3px;
            transition: width 0.6s ease;
            width: 0%;
        }
        .cap-number {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.8rem;
            line-height: 1;
        }
        .cap-number span {
            color: var(--muted);
            font-size: 1rem;
        }

        .main {
            max-width: 1000px;
            margin: 0 auto;
            padding: 0 1.5rem 3rem;
            display: grid;
            grid-template-columns: 1fr 1.35fr;
            gap: 1.5rem;
        }
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            animation: fadeUp 0.6s 0.1s ease both;
        }
        .card-header {
            padding: 1rem 1.2rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255, 255, 255, 0.01);
        }
        .card-title {
            font-family: 'DM Mono', monospace;
            font-size: 0.65rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--silver);
        }
        .card-body {
            padding: 1.2rem;
            flex: 1;
        }

        .field {
            margin-bottom: 0.9rem;
        }
        .field label {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 4px 6px;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.05em;
            color: var(--muted);
            text-transform: uppercase;
            margin-bottom: 4px;
            min-height: 1.2rem;
            line-height: 1.2;
        }
        .field label .hint {
            font-size: 0.55rem;
            font-weight: 400;
            text-transform: none;
            color: var(--green);
            letter-spacing: 0.02em;
            line-height: 1.2;
        }
        input,
        select,
        textarea {
            width: 100%;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            padding: 10px 12px;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            appearance: none;
        }
        input:focus,
        select:focus,
        textarea:focus {
            border-color: var(--red);
            box-shadow: 0 0 0 3px var(--red-glow);
        }
        select option {
            background: var(--surface2);
        }
        textarea {
            resize: vertical;
            min-height: 65px;
        }
        .time-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }
        .btn {
            width: 100%;
            padding: 12px;
            background: var(--red);
            color: white;
            border: none;
            border-radius: 8px;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.1rem;
            letter-spacing: 0.08em;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 0.8rem;
        }
        .btn:hover {
            background: var(--red-dark);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(227, 24, 55, 0.3);
        }
        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .date-picker-trigger {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 10px 12px;
            transition: border-color 0.2s, box-shadow 0.2s;
            min-height: 44px;
            width: 100%;
        }
        .date-picker-trigger:hover {
            border-color: var(--silver-dark);
        }
        .date-picker-trigger.active {
            border-color: var(--red);
            box-shadow: 0 0 0 3px var(--red-glow);
        }
        .date-picker-trigger .date-display {
            font-size: 0.85rem;
            color: var(--text);
            flex: 1;
        }
        .date-picker-trigger .date-display.placeholder {
            color: var(--muted);
            font-weight: 300;
        }
        .date-picker-trigger .date-icon {
            color: var(--muted);
            font-size: 1rem;
        }
        .date-picker-trigger.input-error {
            border-color: var(--red) !important;
            box-shadow: 0 0 0 3px rgba(227, 24, 55, 0.35) !important;
        }

        .date-picker-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(6px);
            z-index: 500;
            justify-content: center;
            align-items: center;
            padding: 1rem;
        }
        .date-picker-modal.open {
            display: flex;
        }
        .date-picker-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.2rem;
            max-width: 400px;
            width: 100%;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8);
            animation: fadeUp 0.25s ease both;
        }
        .date-picker-panel .picker-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            font-family: 'DM Sans', sans-serif;
        }
        .date-picker-panel .picker-header .month-year {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text);
        }
        .date-picker-panel .picker-header .nav-btn {
            background: none;
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--muted);
            width: 34px;
            height: 34px;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Sans', sans-serif;
        }
        .date-picker-panel .picker-header .nav-btn:hover {
            border-color: var(--silver);
            color: var(--text);
        }
        .date-picker-panel .day-names {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 4px;
            margin-bottom: 6px;
            font-family: 'DM Mono', monospace;
            font-size: 0.6rem;
            color: var(--muted);
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .date-picker-panel .day-names span {
            padding: 4px 0;
        }
        .date-picker-panel .date-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 4px;
        }
        .date-picker-panel .date-grid .date-cell {
            padding: 8px 0;
            text-align: center;
            font-size: 0.85rem;
            font-family: 'DM Sans', sans-serif;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            color: var(--muted);
            background: transparent;
            border: 1px solid transparent;
            min-height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .date-picker-panel .date-grid .date-cell:hover:not(.disabled):not(.other-month) {
            background: rgba(255, 255, 255, 0.06);
            color: var(--text);
        }
        .date-picker-panel .date-grid .date-cell.today {
            border-color: var(--silver-dark);
            color: var(--silver);
        }
        .date-picker-panel .date-grid .date-cell.selected {
            background: var(--red);
            color: white;
            font-weight: 600;
            border-color: var(--red);
            box-shadow: 0 0 15px var(--red-glow);
        }
        .date-picker-panel .date-grid .date-cell.disabled {
            opacity: 0.25;
            cursor: not-allowed;
            pointer-events: none;
        }
        .date-picker-panel .date-grid .date-cell.other-month {
            opacity: 0.3;
            cursor: default;
            pointer-events: none;
        }
        .date-picker-panel .picker-actions {
            display: flex;
            gap: 10px;
            margin-top: 1rem;
            justify-content: flex-end;
        }
        .date-picker-panel .picker-actions button {
            padding: 7px 16px;
            border: none;
            border-radius: 8px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.8rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }
        .date-picker-panel .picker-actions .btn-cancel {
            background: transparent;
            color: var(--muted);
            border: 1px solid var(--border);
        }
        .date-picker-panel .picker-actions .btn-cancel:hover {
            background: rgba(255, 255, 255, 0.04);
            color: var(--text);
        }
        .date-picker-panel .picker-actions .btn-done {
            background: var(--red);
            color: white;
        }
        .date-picker-panel .picker-actions .btn-done:hover {
            background: var(--red-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(227, 24, 55, 0.3);
        }

        .date-display-text {
            font-size: 0.75rem;
            color: var(--silver-dark);
            margin-top: 4px;
            font-family: 'DM Mono', monospace;
            letter-spacing: 0.03em;
            min-height: 1.2rem;
        }

        .demographic-note {
            background: rgba(255, 255, 255, 0.03);
            border-left: 3px solid var(--silver-dark);
            padding: 12px 14px;
            font-size: 0.8rem;
            line-height: 1.6;
            color: var(--silver);
            margin-bottom: 1rem;
            border-radius: 0 8px 8px 0;
        }
        .demographic-note strong {
            color: var(--text);
            display: block;
            margin-bottom: 4px;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
        }
        .demographic-note .floor-list {
            display: flex;
            flex-wrap: wrap;
            gap: 6px 12px;
            margin-top: 4px;
        }
        .demographic-note .floor-tag {
            display: inline-block;
            font-size: 0.72rem;
            padding: 2px 8px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
        }
        .demographic-note .floor-tag .gender-m {
            color: var(--silver);
            font-weight: 600;
        }
        .demographic-note .floor-tag .gender-f {
            color: var(--red);
            font-weight: 600;
        }
        .demographic-note .t3-note {
            color: var(--red);
            font-size: 0.7rem;
            display: block;
            margin-top: 4px;
        }

        .room-selector-container {
            display: none;
            background: #0A0A0A;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 12px;
            margin-top: 0.8rem;
            max-height: 400px;
            overflow-y: auto;
            scrollbar-width: thin;
        }
        .room-selector-container::-webkit-scrollbar {
            width: 5px;
        }
