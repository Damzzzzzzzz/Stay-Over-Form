        function updateDemographicNote(towerId) {
            const detail = document.getElementById('demographicDetail');
            const extra = document.getElementById('t3ExtraNote');
            if (!towerId) {
                detail.innerHTML = '<span style="color:var(--muted);font-size:0.75rem;">Select a tower below to view floor gender mapping.</span>';
                extra.textContent = '';
                return;
            }
            const cfg = TOWER_CONFIGS[towerId];
            if (!cfg) {
                detail.innerHTML = '<span style="color:var(--muted);font-size:0.75rem;">Configuration not found.</span>';
                extra.textContent = '';
                return;
            }
            let html = '';
            for (let f = 1; f <= cfg.floors; f++) {
                if (cfg.isValid(f)) {
                    const g = cfg.getGender(f);
                    if (g === 'none') continue;
                    const label = FLOOR_NAMES[f] || 'Floor ' + f;
                    const genderLabel = g.toUpperCase();
                    const cls = g === 'male' ? 'gender-m' : 'gender-f';
                    html += `<span class="floor-tag">${label} <span class="${cls}">● ${genderLabel}</span></span>`;
                }
            }
            detail.innerHTML = html;
            extra.textContent = '';
