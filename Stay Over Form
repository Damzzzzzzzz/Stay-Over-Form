        function generateRoomGrid() {
            const towerId = document.getElementById('hostTower').value;
            const container = document.getElementById('roomSelectorContainer');
            const grid = document.getElementById('dynamicGrid');
            const activeDisplay = document.getElementById('activeRoomDisplay');
            document.getElementById('selectedRoomCode').value = '';
            activeDisplay.style.display = 'none';
            grid.innerHTML = '';
            if (!towerId || !TOWER_CONFIGS[towerId]) { container.style.display = 'none'; return; }
            container.style.display = 'block';
            const config = TOWER_CONFIGS[towerId];
            const halfRooms = config.roomsPerFloor / 2;
            for (let f = 1; f <= config.floors; f++) {
                if (!config.isValid(f)) continue;
                const genderClass = config.getGender(f);
                if (genderClass === 'none') continue;
                const floorDiv = document.createElement('div');
                floorDiv.className = 'floor-group';
                const titleDiv = document.createElement('div');
                titleDiv.className = 'floor-title';
                const genderLabel = genderClass.toUpperCase();
                const tagClass = genderClass === 'male' ? 'male-tag' : 'female-tag';
                titleDiv.innerHTML =
                    `<span>${FLOOR_NAMES[f] || 'Floor ' + f}</span> <span class="gender-tag ${tagClass}">● ${genderLabel} FLOOR</span>`;
                floorDiv.appendChild(titleDiv);
                const wingsDiv = document.createElement('div');
                wingsDiv.className = 'wings-container';
                const leftWing = document.createElement('div');
                leftWing.className = 'wing';
                for (let r = 1; r <= halfRooms; r++) leftWing.appendChild(createRoomButton(towerId, f, r, genderClass));
                const rightWing = document.createElement('div');
                rightWing.className = 'wing';
                for (let r = halfRooms + 1; r <= config.roomsPerFloor; r++) rightWing.appendChild(createRoomButton(towerId, f,
                    r, genderClass));
                wingsDiv.appendChild(leftWing);
                wingsDiv.appendChild(rightWing);
                floorDiv.appendChild(wingsDiv);
                grid.appendChild(floorDiv);
            }
