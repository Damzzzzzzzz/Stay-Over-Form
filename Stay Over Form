        let datePickerTempDate = null;

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  FIREBASE LISTENER
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        function listenForRecords() {
            const ref = db.ref('stayOverRecords');
            ref.on('value', (snapshot) => {
                const data = snapshot.val();
                records = [];
                if (data) {
                    Object.keys(data).forEach(key => {
                        const entry = data[key];
                        entry.firebaseId = key;
                        // Ensure checkedOut field exists
                        if (entry.checkedOut === undefined) entry.checkedOut = false;
                        records.push(entry);
                    });
                }
                if (isLoading) isLoading = false;
                updateDashboardUI();
                if (isAdminLoggedIn) renderAdminList();
            }, (error) => {
                console.error('Firebase read error:', error);
                showToast('Database Error', 'Could not load records. Please refresh.', false);
            });
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  UNIQUE REQUEST ID GENERATOR
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        function generateRequestId() {
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
            let id;
            let attempts = 0;
            do {
                id = '';
                for (let i = 0; i < 8; i++) {
                    id += chars.charAt(Math.floor(Math.random() * chars.length));
                }
                attempts++;
            } while (records.some(r => r.requestId === id) && attempts < 100);
            return id;
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  DATE HELPERS
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        function formatDate(dateStr) {
            if (!dateStr) return 'Not specified';
            const d = new Date(dateStr + 'T12:00:00');
            const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
            const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October',
                'November', 'December'
            ];
            return `${days[d.getDay()]}, ${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
        }

        function formatDateShort(dateStr) {
            if (!dateStr) return '';
            const d = new Date(dateStr + 'T12:00:00');
            const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October',
                'November', 'December'
            ];
            return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
        }

        function formatDateDisplay(date) {
            if (!date) return '';
            const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
            const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October',
                'November', 'December'
            ];
            return `${days[date.getDay()]}, ${date.getDate()} ${months[date.getMonth()]} ${date.getFullYear()}`;
        }

        function formatDateInput(date) {
            if (!date) return '';
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function getToday() {
            const now = new Date();
            return new Date(now.getFullYear(), now.getMonth(), now.getDate());
        }

        function getMinDate() {
            const today = getToday();
            const min = new Date(today);
            min.setDate(today.getDate() + 3);
            return min;
        }

        function dateToStr(date) {
            if (!date) return '';
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function strToDate(str) {
            if (!str) return null;
            const parts = str.split('-');
            return new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
        }

        function isSameDay(a, b) {
            if (!a || !b) return false;
            return a.getFullYear() === b.getFullYear() &&
                a.getMonth() === b.getMonth() &&
                a.getDate() === b.getDate();
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  TOWER CONFIGURATIONS
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        const FLOOR_NAMES = { 1: "Ground Floor", 2: "1st Floor", 3: "2nd Floor", 4: "3rd Floor", 5: "4th Floor",
            6: "5th Floor" };

        const TOWER_CONFIGS = {
            '1': { floors: 6, roomsPerFloor: 22, getGender: (f) => (f <= 2 ? 'male' : 'female'), isValid: (f) => true,
                label: 'Tower 1 – Olympus' },
            '2': {
                floors: 6,
                roomsPerFloor: 22,
                getGender: (f) => {
                    if (f === 1) return 'male';
                    if (f >= 2 && f <= 5) return 'female';
                    if (f === 6) return 'male';
                    return 'none';
                },
                isValid: (f) => f >= 1 && f <= 6,
                label: 'Tower 2 – Phoenix'
            },
            '3': { floors: 6, roomsPerFloor: 12, getGender: (f) => { if (f === 2) return 'male'; if (f === 3) return 'female';
                    return 'none'; }, isValid: (f) => f === 2 || f === 3, label: 'Tower 3 – Apollo' },
            '4': { floors: 6, roomsPerFloor: 22, getGender: (f) => (f <= 2 ? 'male' : 'female'), isValid: (f) => true,
                label: 'Tower 4 – Orion' },
            '5': { floors: 6, roomsPerFloor: 22, getGender: (f) => (f <= 2 ? 'male' : 'female'), isValid: (f) => true,
                label: 'Tower 5 – The Mighty Dragons' }
        };

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  DOM REFS & INIT
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        document.addEventListener('DOMContentLoaded', () => {
            configureMobileElements();
            updateDemographicNote('');
            initTimePicker();
            initDatePicker();
            initEmailJS();
            updateVisibilityForRole();
            listenForRecords();

            document.getElementById('depTime').value = '11:00 AM';

            const minDate = getMinDate();
            const arrDateInput = document.getElementById('arrDate');
            const arrDisplay = document.getElementById('arrDateDisplay');
            arrDateInput.value = dateToStr(minDate);
            arrDisplay.textContent = formatDateDisplay(minDate);
            arrDisplay.classList.remove('placeholder');

            const defaultDep = new Date(minDate);
            defaultDep.setDate(minDate.getDate() + 1);
            const depDateInput = document.getElementById('depDate');
            const depDisplay = document.getElementById('depDateDisplay');
            depDateInput.value = dateToStr(defaultDep);
            depDisplay.textContent = formatDateDisplay(defaultDep);
            depDisplay.classList.remove('placeholder');

            window._arrDateObj = minDate;
            window._depDateObj = defaultDep;

            updateDepMin();
            setTimeout(() => {
                updateDateDisplayText();
            }, 100);
        });

        function configureMobileElements() {
            const isMobile = window.innerWidth <= 820;
            chkRules = isMobile ? document.getElementById('chkRulesMobile') : document.getElementById('chkRulesDesktop');
            chkConsent = isMobile ? document.getElementById('chkConsentMobile') : document.getElementById('chkConsentDesktop');
        }
        window.addEventListener('resize', configureMobileElements);

        function initEmailJS() {
            try {
                emailjs.init(EMAILJS_CONFIG.PUBLIC_KEY);
                console.log('✅ EmailJS initialized');
            } catch (e) { console.warn('⚠️ EmailJS init failed.', e); }
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  DATE PICKER
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        function initDatePicker() {
            const today = getToday();
            datePickerMonth = today.getMonth();
            datePickerYear = today.getFullYear();
            datePickerSelected = null;
            datePickerTempDate = null;
            renderDateGrid();
        }

        function openDatePicker(type) {
            activeDatePicker = type;
            const modal = document.getElementById('datePickerModal');
            modal.classList.add('open');

            const hiddenInput = document.getElementById(type + 'Date');
            const currentVal = hiddenInput.value;
            if (currentVal) {
                const d = strToDate(currentVal);
                if (d) {
                    datePickerSelected = new Date(d);
                    datePickerTempDate = new Date(d);
                    datePickerMonth = d.getMonth();
                    datePickerYear = d.getFullYear();
                } else {
                    const today = getToday();
                    datePickerSelected = null;
                    datePickerTempDate = null;
                    datePickerMonth = today.getMonth();
                    datePickerYear = today.getFullYear();
                }
            } else {
                const today = getToday();
                datePickerSelected = null;
                datePickerTempDate = null;
                datePickerMonth = today.getMonth();
                datePickerYear = today.getFullYear();
            }

            document.querySelectorAll('.date-picker-trigger').forEach(el => el.classList.remove('active'));
            document.getElementById(type + 'DateTrigger').classList.add('active');

            renderDateGrid();
        }

        function closeDatePicker() {
            document.getElementById('datePickerModal').classList.remove('open');
            document.querySelectorAll('.date-picker-trigger').forEach(el => el.classList.remove('active'));
            activeDatePicker = null;
        }

        function changeDateMonth(delta) {
            const newDate = new Date(datePickerYear, datePickerMonth + delta, 1);
            datePickerMonth = newDate.getMonth();
            datePickerYear = newDate.getFullYear();
            renderDateGrid();
        }

        function renderDateGrid() {
            const grid = document.getElementById('dateGrid');
            const header = document.getElementById('datePickerMonthYear');
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September',
                'October', 'November', 'December'
            ];
            header.textContent = `${monthNames[datePickerMonth]} ${datePickerYear}`;

            const firstDay = new Date(datePickerYear, datePickerMonth, 1);
            const lastDay = new Date(datePickerYear, datePickerMonth + 1, 0);
            const daysInMonth = lastDay.getDate();
            let startOffset = firstDay.getDay() - 1;
            if (startOffset < 0) startOffset = 6;

            const today = getToday();
            const minDate = getMinDate();

            let arrivalDate = null;
            if (activeDatePicker === 'dep') {
                const arrVal = document.getElementById('arrDate').value;
                if (arrVal) arrivalDate = strToDate(arrVal);
            }

            grid.innerHTML = '';

            const prevMonthLastDay = new Date(datePickerYear, datePickerMonth, 0).getDate();
            for (let i = startOffset - 1; i >= 0; i--) {
                const day = prevMonthLastDay - i;
                const cell = document.createElement('div');
                cell.className = 'date-cell other-month';
                cell.textContent = day;
                grid.appendChild(cell);
            }

            for (let d = 1; d <= daysInMonth; d++) {
                const cell = document.createElement('div');
                const dateObj = new Date(datePickerYear, datePickerMonth, d);
                const dateStr = dateToStr(dateObj);
                cell.className = 'date-cell';
                cell.textContent = d;
                cell.dataset.date = dateStr;

                if (isSameDay(dateObj, today)) {
                    cell.classList.add('today');
                }

                if (datePickerSelected && isSameDay(dateObj, datePickerSelected)) {
                    cell.classList.add('selected');
                }

                if (dateObj < minDate) {
                    cell.classList.add('disabled');
                }

                if (activeDatePicker === 'dep' && arrivalDate) {
                    const minDep = new Date(arrivalDate);
                    minDep.setDate(arrivalDate.getDate() + 1);
                    if (dateObj < minDep) {
                        cell.classList.add('disabled');
                    }
                }

                cell.addEventListener('click', function() {
                    if (this.classList.contains('disabled') || this.classList.contains('other-month')) return;
                    const dateVal = this.dataset.date;
                    if (dateVal) {
                        const d = strToDate(dateVal);
                        if (d) {
                            datePickerTempDate = new Date(d);
                            document.querySelectorAll('.date-grid .date-cell').forEach(el => el.classList.remove(
                            'selected'));
                            this.classList.add('selected');
                        }
                    }
                });

                grid.appendChild(cell);
            }

            let totalCells = startOffset + daysInMonth;
            const remainder = totalCells % 7;
            if (remainder > 0) {
                const nextMonthDays = 7 - remainder;
                for (let d = 1; d <= nextMonthDays; d++) {
                    const cell = document.createElement('div');
                    cell.className = 'date-cell other-month';
                    cell.textContent = d;
                    grid.appendChild(cell);
                }
            }
        }

        function confirmDatePicker() {
            if (!activeDatePicker) return;
            const selectedCell = document.querySelector('.date-grid .date-cell.selected:not(.other-month)');
            let dateObj = null;
            if (selectedCell && selectedCell.dataset.date) {
                dateObj = strToDate(selectedCell.dataset.date);
            } else if (datePickerTempDate) {
                dateObj = datePickerTempDate;
            } else {
                const cells = document.querySelectorAll('.date-grid .date-cell:not(.disabled):not(.other-month)');
                if (cells.length > 0) {
                    const firstEnabled = cells[0];
                    if (firstEnabled.dataset.date) {
                        dateObj = strToDate(firstEnabled.dataset.date);
                    }
                }
            }

            if (!dateObj) {
                showToast('Date Error', 'Please select a valid date.', false);
                return;
            }

            const minDate = getMinDate();
            if (dateObj < minDate) {
                showToast('Date Error', 'Arrival date must be at least 3 days from today.', false);
                return;
            }

            if (activeDatePicker === 'dep') {
                const arrVal = document.getElementById('arrDate').value;
                if (arrVal) {
                    const arrivalDate = strToDate(arrVal);
                    if (arrivalDate) {
                        const minDep = new Date(arrivalDate);
                        minDep.setDate(arrivalDate.getDate() + 1);
                        if (dateObj < minDep) {
                            showToast('Date Error', 'Departure date must be at least 1 day after arrival.', false);
                            return;
                        }
                    }
                }
            }

            const hiddenInput = document.getElementById(activeDatePicker + 'Date');
            const display = document.getElementById(activeDatePicker + 'DateDisplay');
            hiddenInput.value = dateToStr(dateObj);
            display.textContent = formatDateDisplay(dateObj);
            display.classList.remove('placeholder');

            const displayText = document.getElementById(activeDatePicker + 'ivalDateDisplay');
            if (displayText) {
                displayText.textContent = formatDateShort(dateToStr(dateObj));
            }

            if (activeDatePicker === 'arr') {
                window._arrDateObj = dateObj;
                updateDepMin();
                const depVal = document.getElementById('depDate').value;
                if (depVal) {
                    const depDate = strToDate(depVal);
                    if (depDate) {
                        const minDep = new Date(dateObj);
                        minDep.setDate(dateObj.getDate() + 1);
                        if (depDate < minDep) {
                            const newDep = new Date(minDep);
                            document.getElementById('depDate').value = dateToStr(newDep);
                            const depDisplay = document.getElementById('depDateDisplay');
                            depDisplay.textContent = formatDateDisplay(newDep);
                            depDisplay.classList.remove('placeholder');
                            const depDisplayText = document.getElementById('departureDateDisplay');
                            if (depDisplayText) {
                                depDisplayText.textContent = formatDateShort(dateToStr(newDep));
                            }
                            window._depDateObj = newDep;
                        }
                    }
                }
            } else if (activeDatePicker === 'dep') {
                window._depDateObj = dateObj;
            }

            closeDatePicker();
            renderDateGrid();
        }

        function updateDateDisplayText() {
            const arrVal = document.getElementById('arrDate').value;
            const depVal = document.getElementById('depDate').value;
            const arrDisplayText = document.getElementById('arrivalDateDisplay');
            const depDisplayText = document.getElementById('departureDateDisplay');
            if (arrVal) arrDisplayText.textContent = formatDateShort(arrVal);
            else arrDisplayText.textContent = '';
            if (depVal) depDisplayText.textContent = formatDateShort(depVal);
            else depDisplayText.textContent = '';
        }

        function updateDepMin() {
            const arrVal = document.getElementById('arrDate').value;
            const depDateInput = document.getElementById('depDate');
            const depDisplay = document.getElementById('depDateDisplay');
            const depDisplayText = document.getElementById('departureDateDisplay');

            if (arrVal) {
                const arrDate = strToDate(arrVal);
                if (arrDate) {
                    const minDep = new Date(arrDate);
                    minDep.setDate(arrDate.getDate() + 1);
                    const currentDep = depDateInput.value ? strToDate(depDateInput.value) : null;
                    if (!currentDep || currentDep < minDep) {
                        const newDep = new Date(minDep);
                        depDateInput.value = dateToStr(newDep);
                        depDisplay.textContent = formatDateDisplay(newDep);
                        depDisplay.classList.remove('placeholder');
                        if (depDisplayText) {
                            depDisplayText.textContent = formatDateShort(dateToStr(newDep));
                        }
                        window._depDateObj = newDep;
                    } else {
                        if (depDisplayText) {
                            depDisplayText.textContent = formatDateShort(depDateInput.value);
                        }
                    }
                }
            } else {
                if (depDisplayText) depDisplayText.textContent = '';
            }
            if (document.getElementById('datePickerModal').classList.contains('open')) {
                renderDateGrid();
            }
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  ROLE-BASED VISIBILITY
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        function updateVisibilityForRole() {
            const approvedCard = document.getElementById('approvedStaysCard');
            if (isAdminLoggedIn) {
                approvedCard.classList.add('visible');
            } else {
                approvedCard.classList.remove('visible');
            }
