                closingHtml = '<p>We look forward to having you on hall. Should you have any questions before your arrival, please do not hesitate to reply to this email.</p>';
                return `
              <p>Dear ${entry.name},</p>
              ${statusHtml}
              ${detailsHtml}
              ${closingHtml}
              <p>Yours sincerely,<br /><strong>Damani Smith</strong><br />Off‑Campus Representative 2026‑2027<br />${hallName}</p>
            `;
            } else if (actionType === 'declined') {
                statusHtml = `
              <p style="color: #ef4444; font-weight: bold;">❌ Your request has been declined.</p>
              <p><strong>Request ID: ${entry.requestId}</strong></p>
              <p>If you believe this decision was made in error, or if you would like to resubmit a request with different dates, please contact the Off‑Campus Representative directly.</p>
            `;
                closingHtml = '<p>We understand this may be disappointing, and we encourage you to reach out if you need clarification or wish to explore alternative arrangements.</p>';
                return `
              <p>Dear ${entry.name},</p>
